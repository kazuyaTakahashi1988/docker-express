# Docker Compose
TZ=Asia/Tokyo
APP_PORT=3000
PHPMYADMIN_PORT=8080
PHPMYADMIN_UPLOAD_LIMIT=64M

# MySQL 8.4 LTS
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=express_db
MYSQL_USER=root
MYSQL_PORT=3306
# MySQL 5.7 の既存データディレクトリを直接 8.4 にマウントしないでください。
# dump -> restore で移行するため、デフォルトでは新しいディレクトリを使います。
MYSQL_DATA_DIR=./.data/mysql8.4

# Express
NODE_ENV=development
SESSION_SECRET=change-me-in-local-env
APP_KEY=change-me-in-local-env

# Cloud Run / Cloud SQL / Cloud Storage
# Cloud Run では DB_HOST ではなく Unix socket path を使います。
# DB_SOCKET_PATH=/cloudsql/project-fa900d56-8f52-4a54-867:asia-northeast1:dockerexpress-mysql
# 設定した場合、アップロード画像を Cloud Storage の gs://<bucket>/uploads/ に保存します。
# GCS_BUCKET_NAME=project-fa900d56-8f52-4a54-867-dockerexpress-uploads
GCS_UPLOAD_PREFIX=uploads
# 設定すると、img src や CKEditor の画像 URL にこの base URL を使います。
UPLOADS_BASE_URL=/uploads
SITE_HOST=https://default-hostname.run.app
DEFAULT_OGP_IMAGE_URL=https://storage.googleapis.com/default-uploads/images/common/ogp.png
BUILD_PUSH_COUNT=local
UPLOAD_MAX_BYTES=5242880
