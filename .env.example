# Docker Compose
TZ=Asia/Tokyo
APP_PORT=3000
PHPMYADMIN_PORT=8080
PHPMYADMIN_UPLOAD_LIMIT=64M

# MySQL 8.4 LTS
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=express_db
MYSQL_USER=root
MYSQL_PORT=3306
# MySQL 5.7 の既存データディレクトリを直接 8.4 にマウントしないでください。
# dump -> restore で移行するため、デフォルトでは新しいディレクトリを使います。
MYSQL_DATA_DIR=./.data/mysql8.4

# Express
NODE_ENV=development
SESSION_SECRET=change-me-in-local-env
APP_KEY=change-me-in-local-env
