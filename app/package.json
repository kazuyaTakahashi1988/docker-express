{
  "name": "dockerexpress",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./dist/bin/www.js",
    "dev": "nodemon",
    "build": "tsc",
    "copy:assets": "node ./scripts/copy-assets.cjs",
    "typecheck": "tsc --noEmit",
    "migrate": "npm run build && sequelize-cli --config dist/config/config.js db:migrate",
    "seed": "npm run build && sequelize-cli --config dist/config/config.js db:seed:all",
    "db:reset": "npm run build && sequelize-cli --config dist/config/config.js db:migrate:undo:all && sequelize-cli --config dist/config/config.js db:migrate && sequelize-cli --config dist/config/config.js db:seed:all",
    "audit": "npm audit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.7",
    "debug": "^4.4.3",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "express-validator": "^7.3.2",
    "http-errors": "^2.0.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.22.3",
    "nodemailer": "^7.0.13",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}
