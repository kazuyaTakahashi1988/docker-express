{
  "plugins": ["./scripts/prettier-plugin-ejs-limited.cjs"],
  "singleQuote": false,
  "jsxSingleQuote": false,
  "bracketSameLine": false,
  "semi": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 100,
  "bracketSpacing": true,
  "arrowParens": "always",
  "htmlWhitespaceSensitivity": "ignore",
  "objectWrap": "collapse",
  "overrides": [{ "files": "*.ejs", "options": { "parser": "ejs-limited" } }]
}
