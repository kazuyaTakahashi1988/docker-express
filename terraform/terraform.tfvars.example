# Optional: provide your own passwords. If omitted, Terraform generates them.
# database_password = "change-this"
# root_password     = "change-this"

# Optional: if the principal running `gcloud builds submit` is not a project owner/editor, grant upload access to the Terraform-managed staging bucket.
# build_submitter_members = ["user:you@example.com"]
